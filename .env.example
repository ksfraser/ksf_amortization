# KSF Amortization Environment Variables

# Database
DB_HOST=mysql
DB_NAME=ksf_amortization
DB_USER=ksf_user
DB_PASS=your_secure_password_here

# MySQL
MYSQL_ROOT_PASSWORD=root_password_here

# Redis
REDIS_PASS=redis_password_here

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Cache
CACHE_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=debug
LOG_FILE=/var/log/ksf-amortization/app.log

# API
API_RATE_LIMIT=60
API_TIMEOUT=30
