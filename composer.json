{
    "name": "ksfraser/amortizations-core",
    "description": "Core amortization and loan management engine - shared across all platforms",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "homepage": "https://github.com/ksfraser/ksf_amortization",
    "repositories": [
        {
            "type": "path",
            "url": "../ksfraser-html",
            "options": {
                "symlink": false
            }
        }
    ],
    "require": {
        "php": ">=7.3",
        "brick/math": "^0.9",
        "ksfraser/html": "^1.0 || dev-main",
        "dompdf/dompdf": "^2.0",
        "firebase/php-jwt": "^6.0",
        "league/oauth2-server": "^8.0",
        "ksfraser/ksf-oauth2-server": "^0.1.0",
        "ksfraser/ksf-caching": "^0.1.0",
        "ksfraser/ksf-performance-monitoring": "^0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "9.6"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\Amortizations\\": [
                "src/Ksfraser/Amortizations/",
                "vendor-src/ksf_amortization_core/Ksfraser/Amortizations/"
            ],
            "Ksfraser\\Api\\": "src/Ksfraser/Api/",
            "Ksfraser\\Webhooks\\": "src/Ksfraser/Webhooks/",
            "Ksfraser\\Plugins\\": "src/Ksfraser/Plugins/",
            "Ksfraser\\Localization\\": "src/Ksfraser/Localization/",
            "Ksfraser\\Common\\": "vendor-src/Ksfraser/Common/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": true,
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "test": "phpunit --bootstrap vendor/autoload.php tests/",
        "test-php73": "phpunit --bootstrap vendor/autoload.php --configuration phpunit-php73.xml tests/",
        "test-php74+": "phpunit --bootstrap vendor/autoload.php --configuration phpunit.xml tests/",
        "test-version": "php -v && composer test",
        "test-fa": "cd modules/amortization && composer test",
        "test-wp": "cd modules/wordpress && composer test",
        "test-suite": "cd modules/suitecrm && composer test",
        "test-all": "composer test && composer test-fa && composer test-wp && composer test-suite",
        "init-submodules": "git submodule update --init --recursive",
        "update-submodules": "git submodule update --recursive --remote"
    }
}
